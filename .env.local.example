# .env.local — ArchonHQ (Refactored)
# Copy to .env.local for local dev.
# Never commit real secrets.

# App base URL. Used by NextAuth for redirects.
NEXTAUTH_URL=https://archonhq.ai

# NextAuth signing secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# AUTH_SECRET is the canonical name in NextAuth v5. Set to same value as NEXTAUTH_SECRET.
AUTH_SECRET=

# Postgres connection string.
DATABASE_URL=postgresql://user@localhost/mission_control

# Encryption key for sensitive data. Must decode to exactly 32 bytes.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Google OAuth 2.0. Create credentials at console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Whop product IDs (from your Whop dashboard)
WHOP_COACHING_TEMPLATE_ID=your_coaching_template_product_id
WHOP_CONTENT_PACK_ID=your_content_pack_product_id

# Resend transactional email (for newsletter/contact)
RESEND_API_KEY=
