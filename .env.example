# ── archonhq.ai / Mission Control — Environment Variables ────────────────────
# Copy to .env.local (host) or set via Coolify environment panel (cloud).
# Never commit real values. All secrets should use your secret manager.

# ── App ───────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://archonhq.ai          # Public URL (HTTPS)
NEXTAUTH_SECRET=change_me_32_char_random  # openssl rand -hex 32

# ── Database ──────────────────────────────────────────────────────────────────
# Docker Compose: uses 'db' service hostname automatically
DATABASE_URL=postgresql://openclaw@db/mission_control
# Self-hosted (no Docker): use Unix socket
# DATABASE_URL=postgresql://openclaw@/mission_control?host=/var/run/postgresql

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Mission Control API ───────────────────────────────────────────────────────
API_SECRET=your_bearer_token_here         # Used for agent → MC API calls

# ── OpenClaw Gateway ──────────────────────────────────────────────────────────
# Docker: use host.docker.internal to reach host
GATEWAY_URL=http://host.docker.internal:18789
# Self-hosted: use localhost
# GATEWAY_URL=http://127.0.0.1:18789

# ── Workspace ─────────────────────────────────────────────────────────────────
WORKSPACE_PATH=/home/openclaw/.openclaw/workspace  # Mounted as /workspace in container

# ── Notifications ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Billing (Stripe) ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...
