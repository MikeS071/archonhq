# .env.example — Mission Control (ArchonHQ)
# Copy this file to .env.local for local dev, or paste values into your Coolify environment panel.
# Never commit real secrets. Use a secret manager for anything production-facing.
# Run "bash scripts/new-developer.sh" to automate most of this setup.

# App base URL. Must match the domain you serve the app on. Used by NextAuth for redirects.
NEXTAUTH_URL=https://archonhq.ai

# NextAuth signing secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change_me_32_char_random

# AUTH_SECRET is the canonical name in NextAuth v5. Set it to the same value as NEXTAUTH_SECRET.
AUTH_SECRET=change_me_32_char_random

# Postgres connection string. In Docker Compose the hostname is the service name ('db' or 'postgres').
# For a local bare-metal setup you can use a Unix socket: postgresql://openclaw@/mission_control?host=/var/run/postgresql
DATABASE_URL=postgresql://openclaw@db/mission_control

# Encryption key for sensitive data stored in the database. Must decode to exactly 32 bytes.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=change_me_32_bytes_base64_encoded

# Google OAuth 2.0. Create credentials at console.cloud.google.com and whitelist your redirect URI.
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Bearer token that agents use when calling the Mission Control API. Pick any strong random string.
API_SECRET=your_bearer_token_here

# OpenClaw Gateway address. In Docker use host.docker.internal to reach the host. On bare metal use 127.0.0.1.
GATEWAY_URL=http://host.docker.internal:18789

# Absolute path to the OpenClaw workspace directory. Mounted read-only into the container.
WORKSPACE_PATH=/home/openclaw/.openclaw/workspace

# Telegram bot for push notifications. Leave blank to disable.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Stripe billing. Use test keys (sk_test_...) for local work. Webhook secret comes from your Stripe dashboard.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

# GitHub integration. PAT needs repo and webhook scopes.
GITHUB_PAT=ghp_...
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# Coolify deployment integration. Used by the deploy webhook endpoint.
COOLIFY_API_TOKEN=your_coolify_api_token
COOLIFY_APP_UUID=your_coolify_app_uuid
DEPLOY_WEBHOOK_SECRET=your_deploy_webhook_secret

# AIPipe LLM proxy. Only needed if you use the AI proxy features.
AIPIPE_URL=https://aipipe.example.com
AIPIPE_ADMIN_SECRET=your_aipipe_admin_secret

# OpenAI API key. Used for features that call OpenAI directly rather than via AIPipe.
OPENAI_API_KEY=sk-...

# Resend transactional email. Leave blank to skip email delivery.
RESEND_API_KEY=re_...
