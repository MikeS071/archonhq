# .env.docker-dev
# Environment variables for the Docker-based dev setup (docker-compose.dev.yml).
# These are intentionally non-secret defaults. Do not use these values in production.
# Copy and override any value by editing this file locally. It is gitignored.

# The app binds to this port inside the container.
PORT=3003

# Node environment. Keep this development so Next.js serves hot-reload and verbose errors.
NODE_ENV=development

# Public URL for NextAuth redirects. Matches the exposed port above.
NEXTAUTH_URL=http://localhost:3003

# NextAuth signing secret. This value is fine for local dev only. Generate a real one for production.
NEXTAUTH_SECRET=dev-only-not-a-real-secret-change-for-prod

# Shared signing secret used by NextAuth v5 (AUTH_SECRET is the canonical name in newer versions).
AUTH_SECRET=dev-only-not-a-real-secret-change-for-prod

# Postgres connection string. Points to the 'postgres' service defined in docker-compose.dev.yml.
DATABASE_URL=postgresql://openclaw:devpassword@postgres/mission_control_dev

# Google OAuth credentials. Create a project at console.cloud.google.com and add localhost:3003 as an allowed redirect.
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Bearer token that agents use to talk to the Mission Control API.
API_SECRET=dev-api-secret-change-me

# OpenClaw Gateway URL. host.docker.internal reaches the host machine from inside the container.
GATEWAY_URL=http://host.docker.internal:18789

# Path where the OpenClaw workspace lives. Adjust if your workspace is elsewhere.
WORKSPACE_PATH=/home/openclaw/.openclaw/workspace

# Telegram bot credentials. Leave blank to disable Telegram notifications in dev.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Stripe keys. Use Stripe test mode keys (sk_test_...) for local work. Webhooks need a real key.
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRO_PRICE_ID=price_placeholder
STRIPE_TEAM_PRICE_ID=price_placeholder

# Encryption key for sensitive data stored in the database. Must be 32 bytes when decoded.
ENCRYPTION_KEY=dev-encryption-key-32-bytes-xxxx

# GitHub personal access token. Only needed if you exercise GitHub integration features locally.
GITHUB_PAT=
GITHUB_WEBHOOK_SECRET=

# Coolify deployment integration. Not needed for local dev.
COOLIFY_API_TOKEN=
COOLIFY_APP_UUID=
DEPLOY_WEBHOOK_SECRET=

# AIPipe proxy credentials. Only needed if you test AI proxy features locally.
AIPIPE_URL=
AIPIPE_ADMIN_SECRET=

# OpenAI key. Used for any features that call OpenAI directly (not via AIPipe).
OPENAI_API_KEY=

# Resend API key for transactional email. Leave blank to skip email delivery in dev.
RESEND_API_KEY=
